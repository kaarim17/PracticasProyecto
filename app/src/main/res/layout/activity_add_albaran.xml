<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_titulo_add_albaran"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/titulo_add_albaran"
            android:textAlignment="center"
            android:textColor="#333333"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selecciona el Proveedor:"
            android:textColor="#666666"
            android:layout_marginBottom="8dp"/>

        <Spinner
            android:id="@+id/sp_proveedores"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="#E0E0E0"/>

        <EditText
            android:id="@+id/et_albaran_importe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="@string/hint_importe"
            android:inputType="numberDecimal"
            android:minHeight="48dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/sw_albaran_pagado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/txt_pagado"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/iv_albaran_foto"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp"
            android:background="#E0E0E0"
            android:scaleType="centerCrop" />

        <Button
            android:id="@+id/btn_foto_albaran"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:text="@string/btn_tomar_foto_albaran"
            android:backgroundTint="#2196F3"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_guardar_albaran"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/btn_guardar_albaran"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
