<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/titulo_add_proveedor"
            android:textAlignment="center"
            android:textColor="#333333"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_proveedor_cif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_cif"
            android:inputType="textCapCharacters"
            android:minHeight="48dp" />

        <EditText
            android:id="@+id/et_proveedor_nombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/hint_nombre_empresa"
            android:inputType="textCapWords"
            android:minHeight="48dp" />

        <EditText
            android:id="@+id/et_proveedor_telefono"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/hint_telefono_opcional"
            android:inputType="phone"
            android:minHeight="48dp" />

        <EditText
            android:id="@+id/et_proveedor_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/hint_email_opcional"
            android:inputType="textEmailAddress"
            android:minHeight="48dp" />

        <Button
            android:id="@+id/btn_guardar_proveedor"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="@string/btn_guardar_proveedor"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>